{
  "tasks": [
    {
      "label": "Install Python Dependencies",
      "type": "shell",
      "command": "pip3 install -r python-api/requirements.txt",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Install Node Dependencies",
      "type": "shell",
      "command": "npm install",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Start Python API",
      "type": "shell",
      "command": "cd python-api && python3 -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
      "group": "test",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Start Hono Server",
      "type": "shell",
      "command": "npm run dev:sandbox",
      "group": "test",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Build Project",
      "type": "shell",
      "command": "npm run build",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "pytest python-api/tests/",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ],
  "version": "2.0.0"
}
